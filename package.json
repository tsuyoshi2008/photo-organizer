{
  "name": "photo-organizer",
  "version": "1.0.0",
  "description": "写真を撮影日ごとにフォルダに振り分けるデスクトップアプリ",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "tsuyoshi2008",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "piexifjs": "^1.0.6"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "latest",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "wait-on": "^7.0.1",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3"
  },
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "start": "concurrently \"npm run react-start\" \"npm run electron-start\"",
    "build": "npm run react-build && electron-builder --win",
    "build-mac": "npm run react-build && electron-builder --mac",
    "build-linux": "npm run react-build && electron-builder --linux",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.photoorganizer.app",
    "productName": "Photo Organizer",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
